APP_NAME="Aptoria"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://aptoria.example.com
APP_TIMEZONE=Europe/Budapest

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aptoria
DB_USERNAME=aptoria
DB_PASSWORD=change-this-password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BCRYPT_ROUNDS=12

APTORIA_DEFAULT_LOCALE=en
APTORIA_DEFAULT_ADMIN_EMAIL=admin@example.com
APTORIA_DEFAULT_ADMIN_PASSWORD=change-me-now

# Optional. Leave blank to let Aptoria generate storage/app/setup-token.txt.
# If set, use a long random value with at least 32 characters.
APTORIA_SETUP_TOKEN=
APTORIA_SETUP_TOKEN_MIN_LENGTH=32

# Security header tuning. Keep defaults unless your reverse proxy requires otherwise.
APTORIA_HSTS_MAX_AGE=31536000
APTORIA_HSTS_INCLUDE_SUBDOMAINS=true
APTORIA_HSTS_PRELOAD=false
APTORIA_SENSITIVE_PAGE_NO_STORE=true
APTORIA_CSP_REPORT_ONLY=true
# Monitor alert email delivery. Configure SMTP before using monitor alert emails.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change-this-user
MAIL_PASSWORD=change-this-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=aptoria@example.com
MAIL_FROM_NAME="Aptoria"

