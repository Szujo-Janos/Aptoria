APP_NAME="Aptoria"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Europe/Budapest

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BCRYPT_ROUNDS=12

# APTORIA_VERSION is intentionally not used. VERSION file is the source of truth.
APTORIA_DEFAULT_LOCALE=en
APTORIA_DEFAULT_ADMIN_EMAIL=admin@example.com
APTORIA_DEFAULT_ADMIN_PASSWORD=change-me-now

# Optional. Required to unlock browser-based setup on non-local hosts.
APTORIA_SETUP_TOKEN=

# Security hardening toggles. Defaults are safe for local XAMPP and production.
APTORIA_SETUP_TOKEN_MIN_LENGTH=32
APTORIA_HSTS_MAX_AGE=31536000
APTORIA_HSTS_INCLUDE_SUBDOMAINS=true
APTORIA_HSTS_PRELOAD=false
APTORIA_SENSITIVE_PAGE_NO_STORE=true
APTORIA_CSP_REPORT_ONLY=true
# Monitor alert email delivery. Use log locally, smtp in production.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=aptoria@example.com
MAIL_FROM_NAME="Aptoria"

