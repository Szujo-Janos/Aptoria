APP_NAME=Aptoria
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Europe/Budapest

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional remote installer token. Localhost setup does not require it.
APTORIA_SETUP_TOKEN=

# Aptoria standalone hardening defaults
APTORIA_SESSION_TIMEOUT_MINUTES=120
APTORIA_CSP_REPORT_ONLY=true

# Portable USB / license guard foundation
# Keep false for normal local development. The portable start script sets this to true for guarded runtime starts.
APTORIA_LICENSE_REQUIRED=false
APTORIA_LICENSE_MODE=local_package
APTORIA_LICENSE_FILE=storage/app/aptoria-license.json
APTORIA_LICENSE_PUBLIC_KEY=
APTORIA_LICENSE_PUBLIC_KEY_PATH=storage/app/license-public.pem

# Optional online authority direction.
# Use online_authority or hybrid only for guarded portable/customer runtimes.
APTORIA_LICENSE_AUTHORITY_URL=https://aptoria.dev
APTORIA_LICENSE_AUTHORITY_LEASE_ENDPOINT=/api/license/runtime-lease
APTORIA_LICENSE_AUTHORITY_TIMEOUT_SECONDS=8
APTORIA_LICENSE_OFFLINE_GRACE_HOURS=72
APTORIA_LICENSE_AUTHORITY_PUBLIC_KEY=
APTORIA_LICENSE_AUTHORITY_PUBLIC_KEY_PATH=storage/app/license-authority-public.pem
APTORIA_LICENSE_RUNTIME_LEASE_FILE=storage/app/license-runtime-lease.json

APTORIA_OPENSSL_CONF=
APTORIA_OPENSSL_BINARY=

# Aptoria public demo / live API sandbox
APTORIA_DEMO_MODE=false
APTORIA_DEMO_API_BASE_URL=${APP_URL}/demo-api
APTORIA_DEMO_API_TOKEN=aptoria-demo-token
APTORIA_DEMO_ALLOWED_TARGETS=
APTORIA_DEMO_USER_EMAIL=demo@aptoria.dev
APTORIA_DEMO_USER_PASSWORD=aptoria-demo-2026
