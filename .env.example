APP_NAME=Aptoria
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Europe/Budapest

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Normal downloadable/customer application mode.
APTORIA_DOMAIN_ROLE=local

# Public project links.
APTORIA_GITHUB_URL=https://github.com/Szujo-Janos
APTORIA_DOWNLOAD_URL=https://github.com/Szujo-Janos/aptoria/releases
APTORIA_DOCS_URL=https://github.com/Szujo-Janos/aptoria/tree/main/docs
APTORIA_SUPPORT_URL=https://github.com/Szujo-Janos/aptoria/issues

# License activation is part of the distributed product.
# Do not commit generated license files or key material.
APTORIA_LICENSE_REQUIRED=true
APTORIA_LICENSE_FILE=storage/app/aptoria-license.json
APTORIA_LICENSE_PUBLIC_KEY_PATH=storage/app/license-public.pem

# Public demo features are disabled in the downloadable app.
APTORIA_DEMO_MODE=false
