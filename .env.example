# Base local example. For deployment-specific templates, see hosting-profiles/.
APP_NAME=Aptoria
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Europe/Budapest

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional remote installer token. Localhost setup does not require it.
APTORIA_SETUP_TOKEN=

# Aptoria standalone hardening defaults
APTORIA_SESSION_TIMEOUT_MINUTES=120
APTORIA_CSP_REPORT_ONLY=true

# Subdomain/domain role separation.
# local/customer: normal standalone Aptoria app
# landing: aptoria.dev public landing only
# demo: demo.aptoria.dev public demo only
APTORIA_DOMAIN_ROLE=local
APTORIA_LANDING_URL=https://aptoria.dev
APTORIA_DEMO_URL=https://demo.aptoria.dev
APTORIA_ADMIN_URL=https://admin.aptoria.dev
APTORIA_LICENSE_URL=https://license.aptoria.dev

# Public landing links. Keep these external in landing mode so aptoria.dev stays a public product page.
APTORIA_GITHUB_URL=https://github.com/Szujo-Janos/Aptoria
APTORIA_DOWNLOAD_URL=https://github.com/Szujo-Janos/Aptoria/releases
APTORIA_DOCS_URL=https://github.com/Szujo-Janos/Aptoria/tree/main/docs
APTORIA_SUPPORT_URL=https://github.com/Szujo-Janos/Aptoria/issues

# Portable USB / license guard foundation
# Keep false for normal local development. The portable start script sets this to true for guarded runtime starts.
APTORIA_LICENSE_REQUIRED=false
APTORIA_LICENSE_MODE=local_package
APTORIA_LICENSE_FILE=storage/app/aptoria-license.json
APTORIA_LICENSE_PUBLIC_KEY=
APTORIA_LICENSE_PUBLIC_KEY_PATH=storage/app/license-public.pem

# Optional online authority direction.
# Use online_authority or hybrid only for guarded portable/customer runtimes.
# The public authority itself is configured in license-issuer/config.php.
APTORIA_LICENSE_AUTHORITY_URL=https://license.aptoria.dev
APTORIA_LICENSE_AUTHORITY_LEASE_ENDPOINT=/api/license/runtime-lease
APTORIA_LICENSE_AUTHORITY_TIMEOUT_SECONDS=8
APTORIA_LICENSE_OFFLINE_GRACE_HOURS=72
APTORIA_LICENSE_AUTHORITY_PUBLIC_KEY=
APTORIA_LICENSE_AUTHORITY_PUBLIC_KEY_PATH=storage/app/license-authority-public.pem
APTORIA_LICENSE_RUNTIME_LEASE_FILE=storage/app/license-runtime-lease.json

APTORIA_OPENSSL_CONF=
APTORIA_OPENSSL_BINARY=

# Aptoria public demo / live API sandbox
APTORIA_DEMO_MODE=false
APTORIA_DEMO_API_BASE_URL=${APP_URL}/demo-api
APTORIA_DEMO_API_TOKEN=aptoria-demo-token
APTORIA_DEMO_ALLOWED_TARGETS=
# In APTORIA_DEMO_MODE=true, an empty allowlist is fail-closed and blocks external scan targets.
APTORIA_DEMO_VIEWER_READ_ONLY=true
# readonly: every demo viewer POST/PUT/PATCH/DELETE is blocked.
# showcase: demo viewer can browse the full prebuilt workspace; unsafe write/admin actions stay blocked.
APTORIA_DEMO_VIEWER_MODE=showcase
APTORIA_DEMO_SHOWCASE_PROJECT_SLUG=aptoria-full-demo-workspace
APTORIA_DEMO_AUTO_OPEN_SHOWCASE=true
APTORIA_DEMO_RESET_PRUNE_STORAGE=true
APTORIA_DEMO_RESET_FLUSH_CACHE=true
APTORIA_DEMO_RESET_STORAGE_PATHS=demo,demo-api,demo-uploads
APTORIA_DEMO_USER_EMAIL=demo@aptoria.dev
APTORIA_DEMO_USER_PASSWORD=aptoria-demo-2026

# Validate the active profile before deployment with:
# php artisan aptoria:hosting-diagnostics
# php artisan aptoria:hosting-diagnostics --strict

# Deployment readiness / installer preflight:
# php artisan aptoria:deployment-preflight
# php artisan aptoria:deployment-preflight --strict
# php artisan aptoria:deployment-preflight --installer

# Subdomain smoke result import and deployment dashboard.
APTORIA_SMOKE_RESULTS_PATH=storage/app/aptoria-deployment/smoke-results
APTORIA_SMOKE_RESULT_MAX_AGE_HOURS=24
APTORIA_SMOKE_RESULT_HISTORY_LIMIT=20
# Generate importable JSON with:
# PowerShell: .\scripts\smoke-subdomains.ps1 -JsonOutput storage\app\aptoria-deployment\smoke-result.json
# Bash: APTORIA_SMOKE_JSON_OUTPUT=storage/app/aptoria-deployment/smoke-result.json ./scripts/smoke-subdomains.sh
# Import with: php artisan aptoria:subdomain-smoke-import storage/app/aptoria-deployment/smoke-result.json
